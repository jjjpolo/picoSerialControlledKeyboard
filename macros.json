{
  "bootup_sequence": [
    {"type": "hotkey", "keys": ["GUI", "R"]},
    {"type": "delay", "seconds": 1.0},
    {"type": "write", "text": "bootup sequence"},
    {"type": "delay", "seconds": 1.0},
    {"type": "press", "key": "ESCAPE"},
    {"type": "delay", "seconds": 10.0}
  ],
  "shutdown": [
    {"type": "hotkey", "keys": ["GUI", "R"]},
    {"type": "delay", "seconds": 0.2},
    {"type": "write", "text": "shutdown /s /t 0"},
    {"type": "delay", "seconds": 0.1},
    {"type": "press", "key": "ENTER"}
  ],
  "gitbash": [
    {"type": "hotkey", "keys": ["LEFT_CONTROL", "LEFT_ALT", "T"]}
  ],
  "lock": [
    {"type": "hotkey", "keys": ["GUI", "L"]}
  ],
    "theine": [
    {"type": "hotkey", "keys": ["GUI"]},
    {"type": "delay", "seconds": 0.2},
    {"type": "write", "text": "theine"},
    {"type": "delay", "seconds": 0.1},
    {"type": "press", "key": "ENTER"}
  ],
    "unlock": [
    {"type": "hotkey", "text": ["1234"]},
    {"type": "press", "key": "ENTER"}
  ]  
}